{
  "name": "kchng-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "KCHNG - A Stellar blockchain community currency with demurrage",
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:contracts": "cd packages/contracts && cargo test && cargo clippy",
    "lint": "pnpm -r lint",
    "clean": "rm -rf node_modules packages/*/node_modules",
    "prepare": "husky"
  },
  "keywords": [
    "stellar",
    "soroban",
    "blockchain",
    "demurrage",
    "community-currency"
  ],
  "author": "KCHNG",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
